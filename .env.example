# ----------------------------------------------------------------------------
# Lesson Scheduling - environment configuration
# Copy this file to `.env` and fill in real values before `docker compose up`.
# ----------------------------------------------------------------------------

# --- PostgreSQL (used by both the `db` and `api` containers) ---
POSTGRES_USER=lessons
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=lessons

# Connection string the API uses to reach Postgres.
# Host is the compose service name `db`. Keep user/password/db in sync above.
DATABASE_URL=postgres://lessons:change-me-strong-password@db:5432/lessons

# --- Auth ---
# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
# How long a login session lasts.
JWT_EXPIRES_IN=7d
# Set to `true` when serving over HTTPS so auth cookies are marked Secure.
COOKIE_SECURE=false

# --- App URLs ---
# Public URL of the site (used in emails and CORS). e.g. https://lessons.example.com
CLIENT_URL=http://localhost:8080
# Port the `web` (nginx) container is published on.
WEB_PORT=8080
# Internal port the API listens on (inside its container).
PORT=4000

# --- Email (optional) ---
# If these are unset, emails are printed to the API container logs instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Lesson Scheduling <no-reply@example.com>"

# Hours before a lesson to send a reminder email.
REMINDER_LEAD_HOURS=24
