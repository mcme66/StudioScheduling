# ----------------------------------------------------------------------------
# LOCAL (no-Docker) configuration for the API.
# Copy this file to `server/.env` and adjust for your local PostgreSQL.
# (The root-level .env is only used by Docker Compose.)
# ----------------------------------------------------------------------------

# Point at your locally-installed PostgreSQL. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lessons

# Auth. Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# The Vite dev server origin (used for CORS / email links).
CLIENT_URL=http://localhost:5173
PORT=4000

# Email is optional locally. Leave SMTP_* blank to print emails to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Lesson Scheduling <no-reply@example.com>"

REMINDER_LEAD_HOURS=24
